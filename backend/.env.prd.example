# AgentFlow PRD Compliance Environment Variables

# Core Database
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Instagram Integration (PRD Compliance)
INSTAGRAM_ACCESS_TOKEN=your_instagram_business_access_token
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# Slack Integration (HITL Notifications)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_HITL_CHANNEL=#hitl-approvals
SLACK_NOTIFICATIONS_CHANNEL=#agent-updates

# HubSpot CRM Integration
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
HUBSPOT_CLIENT_ID=your_hubspot_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret

# Qdrant Vector Database (Multitenancy)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key

# Neo4j Graph Database (Graphiti)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Redis/Upstash (Priority Queues)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# Analytics (Optional)
MIXPANEL_TOKEN=your_mixpanel_token

# Security
JWT_SECRET=your_jwt_secret_key
ENCRYPTION_KEY=your_encryption_key

# PRD-Specific Settings
HITL_TIMEOUT_HOURS=24
INSTAGRAM_COMPLIANCE_STRICT=true
QUEUE_RATE_LIMIT_ENABLED=true
AUDIT_LOGGING_ENABLED=true