# OpenRouter API (Required for LLM calls)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase Configuration (Optional - will use demo mode if not provided)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret

# Neo4j Configuration (Optional - will use fallback if not provided)
NEO4J_URI=neo4j+s://your-neo4j-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Qdrant Configuration (Optional - will use fallback if not provided)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# Redis Configuration (Optional - will use fallback if not provided)
REDIS_URL=redis://localhost:6379

# Application Settings
DEBUG=true
APPROVAL_MODE=manual
LOG_LEVEL=INFO